package components

import (
	"github.com/sonr-io/motr/sink"
	ui "github.com/sonr-io/motr/ui/base"
	"github.com/sonr-io/motr/x/auth/types"
)

var meta = sink.DefaultMetadata()

templ LoginView(opts types.LoginOptions) {
	@ui.HTML() {
		@ui.Head() {
			@ui.MetaComponent(meta)
		}
		<sl-tab-group>
			@ui.Nav() {
				@ui.NavLeft() {
					@ui.NavLogo("Motr")
				}
				@ui.NavRight() {
				}
			}
			@ui.Body() {
			}
		</sl-tab-group>
	}
}
