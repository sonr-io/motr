package components

import "github.com/sonr-io/motr/internal/ui"

templ RegisterView() {
	@ui.HTML() {
		@ui.Head() {
			@ui.MetaComponent(meta)
		}
		<sl-tab-group>
			@ui.Nav() {
				@ui.NavLeft() {
					@ui.NavLogo("Motr")
				}
				@ui.NavRight() {
				}
			}
			@ui.Body() {
				@ui.Container() {
					@HandleInitial()
				}
			}
		</sl-tab-group>
	}
}
