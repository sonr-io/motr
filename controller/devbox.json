{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.14.1/.schema/devbox.schema.json",
  "packages": [
    "bun@latest",
    "go@latest",
    "templ@latest"
  ],
  "shell": {
    "init_hook": [
      "bun install wrangler -g",
      "go install github.com/syumai/workers/cmd/workers-assets-gen@latest"
    ],
    "scripts": {
      "build": [
        "templ generate",
        "go run github.com/syumai/workers/cmd/workers-assets-gen -mode=go",
        "GOOS=js GOARCH=wasm go build -o ./build/app.wasm ."
      ],
      "deploy": [
        "wrangler deploy"
      ],
      "start": [
        "wrangler dev"
      ],
      "generate": [
        "templ generate"
      ]
    }
  }
}
