{
	"name": "@sonr-io/motr-controller",
	"version": "0.0.1",
	"private": true,
	"scripts": {
		"build": "npm run templ && npm run build:assets && npm run build:wasm",
		"build:assets": "go run github.com/syumai/workers/cmd/workers-assets-gen -mode=go",
		"build:wasm": "GOOS=js GOARCH=wasm go build -o ./build/app.wasm .",
		"deploy": "wrangler deploy",
		"templ": "templ generate",
		"start": "wrangler dev"
	},
	"devDependencies": {
		"wrangler": "^4.10.0"
	}
}
