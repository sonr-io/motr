{
  "name": "@sonr-io/motr-web",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dist": "go run github.com/syumai/workers/cmd/workers-assets-gen -mode=go -o=./cmd/web/build",
    "generate": "templ generate",
    "build": "GOOS=js GOARCH=wasm go build -o ./build/app.wasm .",
    "migrate": "npx wrangler d1 execute motr-db --remote --file=./schema.sql",
    "deploy": "npx wrangler deploy",
    "start": "npx wrangler dev"
  },
  "dependencies": {
    "@extism/extism": "^2.0.0-rc11",
    "@helia/dag-cbor": "^1.0.1",
    "@helia/dag-json": "^1.0.1",
    "@helia/json": "^1.0.1",
    "@helia/strings": "^1.0.1",
    "@helia/unixfs": "^1.4.1",
    "helia": "^2.1.0",
    "sonr-cosmes": "^0.0.5"
  },
  "devDependencies": {
    "wrangler": "^4.10.0"
  }
}
