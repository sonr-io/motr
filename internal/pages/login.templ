package pages

import "github.com/sonr-io/motr/ui"

templ LoginView() {
	@ui.HTML() {
		@ui.Head() {
			@ui.MetaComponent(meta)
		}
		@ui.Nav() {
			@ui.NavLeft() {
				@ui.NavLogo("Sonr") {
					<div style="font-size: 24px;">
						<sl-icon library="sonr" name="sonr"></sl-icon>
					</div>
				}
			}
			@ui.NavRight() {
			}
		}
		@ui.Body() {
		}
	}
}
