package login

import "github.com/sonr-io/motr/internal/ui"
import "github.com/sonr-io/motr/pkg/session"

templ LoginView() {
	@ui.HTML() {
		@ui.Head() {
			@session.DefaultMetaComponent()
			@ui.DefaultMetaComponent()
		}
		@ui.Nav() {
			@ui.NavLeft() {
				@ui.NavLogo("Sonr") {
					<div style="font-size: 24px;">
						<sl-icon library="sonr" name="sonr"></sl-icon>
					</div>
				}
			}
			@ui.NavRight() {
			}
		}
		@ui.Body() {
		}
	}
}
