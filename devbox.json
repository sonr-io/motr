{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.14.1/.schema/devbox.schema.json",
  "packages": [
    "templ@latest",
    "sqlc@latest",
    "nodejs@latest",
    "gum@latest",
    "goreleaser@latest",
    "commitizen@latest"
  ],
  "shell": {
    "init_hook": [
      "make tidy"
    ],
    "scripts": {
      "build": [
        "make build-radar",
        "make build-worker"
      ],
      "deploy": [
        "make deploy-radar",
        "make deploy-worker"
      ],
      "release": [
        "goreleaser check",
        "goreleaser release --clean"
      ],
      "gen:sqlc": [
        "sqlc generate -f ./internal/db/sqlc.yaml"
      ],
      "gen:templ": [
        "templ generate"
      ]
    }
  }
}
