{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.14.1/.schema/devbox.schema.json",
  "packages": [
    "templ@latest",
    "sqlc@latest",
    "nodejs@latest",
    "goreleaser@latest",
    "doppler@latest",
    "commitizen@latest"
  ],
  "shell": {
    "init_hook": [
      "source .github/setup_env.sh",
      "go_tidy"
    ],
    "scripts": {
      "deploy": [
        "check_deps",
        "check_vars",
        "wrangler_deploy $RADAR_ROOT",
        "wrangler_deploy $WORKER_ROOT"
      ],
      "release": [
        "check_deps",
        "check_vars",
        "publish_release"
      ],
      "install:radar": [
        "cd $RADAR_ROOT && npm install"
      ],
      "install:worker": [
        "cd $WORKER_ROOT && npm install"
      ],
      "build:radar": [
        "templ generate",
        "GOOS=js GOARCH=wasm go build -o ./cmd/radar/build/app.wasm ./cmd/radar/main.go"
      ],
      "build:worker": [
        "templ generate",
        "GOOS=js GOARCH=wasm go build -o ./cmd/worker/build/app.wasm ./cmd/worker/main.go"
      ],
      "gen:sqlc": [
        "sqlc generate"
      ],
      "gen:templ": [
        "templ generate"
      ]
    }
  }
}
